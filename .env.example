# ============================================================================
# AurvexAI configuration (EXAMPLE). Copy to .env and fill in.
# NEVER commit a real .env. Secrets live ONLY here, never in code.
# ============================================================================

# -- Mode --------------------------------------------------------------------
AX_MODE=paper                 # paper | live  (live is gated & stubbed; keep paper)
LOG_LEVEL=INFO

# -- Market data -------------------------------------------------------------
# ccxt      = real Binance USDT-M futures PUBLIC data (no API key needed)
# synthetic = fully offline deterministic data (for demo/CI)
DATA_PROVIDER=ccxt
EXCHANGE_ID=binanceusdm
LTF=1m
HTF=15m
LTF_LIMIT=120
HTF_LIMIT=60
UNIVERSE_SIZE=40
MAX_SYMBOLS_PER_CYCLE=40
CYCLE_INTERVAL_SEC=20

# -- Scoring / thresholds ----------------------------------------------------
TRADE_THRESHOLD=60
WATCHLIST_THRESHOLD=50

# -- Risk profile ------------------------------------------------------------
# Named profile that supplies the account-level defaults below. An explicit
# value for any of the keys below ALWAYS overrides the profile default.
#   aggressive_paper   (DEFAULT, new epoch): 200 / 2% / 1-3% band / 10% daily
#   conservative_paper (legacy paper)      : 1000 / 0.5% / 0.25-1% band / 3%
# Config-only: this changes sizing INPUTS, never the decide() allow/reject path.
RISK_PROFILE=aggressive_paper

# -- Risk --------------------------------------------------------------------
RISK_PCT=2.0                  # % of balance = max NET loss per trade (price move
                              # to the stop + commission + assumed slippage). A
                              # full stop is ~ -1.0R, not -1.43R.
MIN_RISK_PCT=1.0              # risk band floor (must satisfy MIN <= RISK <= MAX <= 5)
MAX_RISK_PCT=3.0             # risk band ceiling
MAX_OPEN_TRADES=4
MAX_DAILY_LOSS_PCT=10.0
# Daily profit lock (profit-side mirror of the kill switch). Once today's UTC
# REALIZED PnL >= balance * DAILY_PROFIT_LOCK_PCT / 100, new entries are
# rejected (reason "daily_profit_lock"). Open trades keep their normal exit
# management; the lock resets at UTC day rollover.
DAILY_PROFIT_LOCK_ENABLED=true
DAILY_PROFIT_LOCK_PCT=10.0
MAX_LEVERAGE=10
FREE_MARGIN_RESERVE_PCT=20    # keep this % of balance free; spread the rest over
                              # open slots to pick a slot-aware target margin
COIN_COOLDOWN_MINUTES=20
MIN_STOP_DIST_PCT=0.30
MAX_STOP_DIST_PCT=2.50
TP1_R=1.5
TP2_R=2.5
TP3_R=4.0
# Scale-out fractions at TP1/TP2/TP3 (+ runner). Must sum to 1.0 (validated).
TP1_FRAC=0.5
TP2_FRAC=0.3
TP3_FRAC=0.2
MOVE_SL_TO_BE_AFTER_TP1=true   # after TP1, move SL to cost-adjusted break-even
TIME_STOP_BARS=0               # >0: cut a trade after N bars w/o TP/SL (exit "TIME"); 0=off

# -- Leverage / margin safety ------------------------------------------------
# Leverage NEVER grows notional or risk; it only sets how much margin a
# risk-sized notional locks. The stop is always kept inside the modelled
# liquidation by LIQ_SAFETY_BUFFER.
# efficient   = highest liquidation-safe leverage -> least locked margin (same
#               max loss, more free capital). conservative = legacy slot-fit min.
LEVERAGE_POLICY=efficient
MAINT_MARGIN_RATE=0.005        # >= exchange tier-1 maint margin (safer = higher)
LIQ_SAFETY_BUFFER=2.0          # est. liquidation must be >= this x stop distance

# -- Strategy profile --------------------------------------------------------
# aurvex_enhanced  = same 5-condition TA core + ATR-adaptive stop (default).
# bugra_replica    = same TA core + fixed-% stop/TP (Bugra system replica).
# reversion_v1     = additive mean-reversion entry (Bollinger stretch + ranging
#                    LTF + RSI), maker-friendly fixed-% stop + single quick TP.
# squeeze_breakout = volatility-squeeze breakout (VALIDATED @1h: net +0.088R,
#                    PF 1.12, DSR +1.58). Deploy with: LTF=1h HTF=4h
#                    LTF_LIMIT=525 TIME_STOP_BARS=48 (or ts=24 in STRATEGIES).
# donchian_trend   = 20-bar channel breakout trend runner (VALIDATED @4h:
#                    net +0.284R, PF 1.37, DSR +2.44 — the strongest edge).
#                    Deploy with: LTF=4h HTF=1d LTF_LIMIT=525 TIME_STOP_BARS=0.
# (Legacy multi-setup profile was removed; one detector runs per profile.
#  aurvex_enhanced/bugra_replica/reversion_v1 are RETIRED scalp profiles —
#  formal NO-GO, kept for reproducibility only. See SYSTEM_STATE.md; the
#  recommended deployment is the multi-strategy pairing below.)
STRATEGY_PROFILE=aurvex_enhanced

# Multi-strategy (portfolio) mode: run SEVERAL validated edges on ONE account
# — one balance, one kill switch, one profit lock, one slot pool — each entering
# on its own timeframe and exiting by its own rule. Empty = single-strategy
# (STRATEGY_PROFILE above). Format: "profile@ltf/htf[:ts=N][:ch=N]" specs.
# The validated pairing (donchian trend runner 4h + squeeze breakout 1h):
#   STRATEGIES=donchian_trend@4h/1d squeeze_breakout@1h/4h:ts=24
# When set, also set GLOBAL_RANKING=true so both strategies' candidates compete
# fairly for the shared slots, and LTF_LIMIT high enough for the largest TF.
STRATEGIES=

# -- Mean-reversion (reversion_v1) parameters --------------------------------
# Only read by the reversion entry + its exit branch; a non-reversion run is
# byte-identical with these set. Exit = single quick TP at REV_TP_R taking 100%
# (snap-and-out: no break-even move, no runner).
REV_BB_N=20          # Bollinger lookback (closed bars)
REV_BB_K=2.0         # Bollinger band width (k·σ)
REV_ADX_MAX=22       # LTF must be ranging: ADX < this
REV_HTF_ADX_MAX=25   # HTF trend-strength ceiling for the opposing-trend guard
REV_RSI_LONG=30      # LONG requires RSI < this (oversold)
REV_RSI_SHORT=70     # SHORT requires RSI > this (overbought)
REV_SL_PCT=1.5       # fixed-% stop distance (clamped by the stop-normalizer)
REV_TP_R=1.2         # single TP at +1.2R (takes 100%)

# -- Squeeze-breakout parameters (STRATEGY_PROFILE=squeeze_breakout) ----------
# Faithful to the validated research rules; only the squeeze setup + its risk
# branches read these. Exit = stop or TIME_STOP_BARS; no profit target
# (SQZ_TP_R is an unreachable sentinel keeping the 3-slot TP contract).
SQZ_WINDOW=24            # range window (bars) for squeeze + breakout levels
SQZ_PCTILE=20            # squeeze = range at/below this percentile of baseline
SQZ_BASELINE=500         # trailing ranges in the percentile baseline (min 100)
SQZ_STOP_MULT=1.0        # stop = this × the W-bar range
SQZ_TP_R=1000            # unreachable single TP (do not lower casually)
MAX_STOP_DIST_PCT_SQZ=10.00  # stop ceiling for the structural range stop

# -- Bugra replica parameters (used when STRATEGY_PROFILE=bugra_replica) ------
MAX_STOP_DIST_PCT_BUGRA=5.00   # wider stop ceiling for the fixed-% bugra stop
BUGRA_STOP_PCT=4.49
BUGRA_TP1_PCT=1.50
BUGRA_TP2_PCT=2.80
BUGRA_TP3_PCT=4.49
BUGRA_EMA_FAST=9
BUGRA_EMA_SLOW=21
BUGRA_ST_PERIOD=10
BUGRA_ST_MULT=3.0
BUGRA_ADX_MIN=20.0

# -- Runner + adaptive trailing stop -----------------------------------------
# runner_frac>0 keeps a fraction past TP3, trailed by TRAIL_MODE. When >0 the
# TP fractions above must be lowered so TP1+TP2+TP3+RUNNER == 1.0, e.g.
# 0.35/0.30/0.20/0.15.
RUNNER_FRAC=0.0
TRAIL_MODE=atr                 # atr | supertrend | kijun | swing
TRAIL_ATR_MULT=0.7
TRAIL_SWING_BARS=5

# -- Microstructure guards ---------------------------------------------------
MAX_SPREAD_PCT=0.06
MAX_SLIPPAGE_PCT=0.08

# -- Costs -------------------------------------------------------------------
TAKER_FEE_PCT=0.045
SLIPPAGE_ASSUMPTION_PCT=0.02
# 8h perp funding applied as a backtest holding cost (net-of-cost expectancy).
# 0.0 = off (synthetic data has no funding); real-data runs use e.g. 0.0001.
FUNDING_RATE_8H=0.0

# -- Paper account -----------------------------------------------------------
INITIAL_PAPER_BALANCE=200      # aggressive_paper default (was 1000 in conservative)

# -- Universe curation (CE-1 Wave 2) ----------------------------------------
# Comma-separated full CCXT symbols to ban from the universe entirely.
# These are the 8 worst performers identified from shadow data (avg R < -0.5R):
#   XLM/USDT:USDT, FIL/USDT:USDT, ADA/USDT:USDT, INTC/USDT:USDT,
#   TRUMP/USDT:USDT, NEAR/USDT:USDT, SOL/USDT:USDT, LAB/USDT:USDT
# Root cause: highly-liquid crypto majors are efficient/choppy; trend-following
# setups get cut up. Forward-test before adding more. Default: empty (no ban).
UNIVERSE_EXCLUDE=

# -- Session filter (CE-2 Wave 2) -------------------------------------------
# Comma-separated UTC hours to allow trading in, e.g. "10,11,12,13".
# Shadow data: UTC 11-12 ~+0.24R; dead Asya saatleri (UTC 01-02, 06-07) ~-0.6R.
# Empty = all hours allowed (default, backward-compatible).
# Forward-test this AFTER CE-1 (universe exclude) in isolation.
TRADE_HOURS_UTC=

# -- Buğra primary gate: score/Shadow as SUPPORT, not a veto -----------------
# Buğra is the primary entry gate. Score only ranks slots and modulates risk,
# and only in the MEASURED edge direction. These defaults keep an unvalidated
# score from blocking or amplifying trades.
SCORE_AS_GATE=false           # false (default): score is advisory, never vetoes
                              # true: legacy score<threshold → REJECT/WATCH gate
MIN_EXECUTION_SCORE=0.0       # 0 (default)=no floor. >0: opt-in soft floor only
GLOBAL_RANKING=true           # true (default): two-pass rank allocation for slots
RANK_KEY=edge                 # edge (default)|composite|score — edge follows
                              # measured score-bucket avg_r, neutral when N<100
RISK_MODULATION_ENABLED=false # false (default): risk multiplier pinned to 1.0
                              # (byte-identical sizing). true: modulate within
                              # caps by measured edge (shadow avg_r · score avg_r)

# -- Shadow learner ----------------------------------------------------------
SHADOW_MIN_SCORE=45
SHADOW_MAX_BARS=120
SHADOW_APPLY=false            # observe-first; true = soft score nudges only

# -- Setup-level shadow-only observation (Wave 2) ----------------------------
# Setups listed here are scored and tracked in shadow but never executed.
# Use to observe weak setups without taking risk. Default: empty (trade all).
SHADOW_ONLY_SETUPS=

# -- ADX trend gate (CE-5 Wave 2) -------------------------------------------
# Minimum HTF ADX required for trend_continuation to fire.
# 0.0 = gate disabled (default). Set e.g. 20.0 to suppress chop-day signals.
# Ablation-test in backtest/replay before enabling in paper.
MIN_HTF_ADX_TREND=0.0

# -- Governor (read-only daily report; NEVER a runtime layer) ----------------
# `python main.py report [--telegram]` reads the DB and prints/sends a system
# report. It runs as a separate read-only process and has NO trade/risk/live/
# config-write authority. These flags document that intent (all must stay false).
GOVERNOR_MODE=report_only
GOVERNOR_CAN_TRADE=false
GOVERNOR_CAN_CHANGE_LIVE=false
GOVERNOR_CAN_AUTO_APPLY=false
GOVERNOR_REQUIRES_APPROVAL_FOR_RISK_INCREASE=true
# Setup-health / risk-throttle analyzers are report-only suggestions (Phase 6).
RISK_THROTTLE_MODE=report_only

# -- Storage -----------------------------------------------------------------
DB_PATH=data/aurvex.db

# -- Dashboard ---------------------------------------------------------------
# IF-1 (Wave 2): bind to localhost only; access via SSH tunnel or reverse proxy.
# Change to 0.0.0.0 only if behind a firewall/auth layer (e.g. nginx + basic auth).
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
# Optional HTTP Basic auth (Task 4). When BOTH are set, every dashboard route
# requires credentials EXCEPT /health (docker healthcheck). Unset = open
# (unchanged behaviour). Strongly recommended when the port is published.
DASHBOARD_AUTH_USER=
DASHBOARD_AUTH_PASS=
# ENGINE LOOP staleness cut (ms) for the dashboard badge. Heartbeat is written
# at cycle END; default = max(120000, 6 x CYCLE_INTERVAL_SEC x 1000).
HEARTBEAT_STALE_MS=

# Stale-data guard for NEW entries: if the freshest CLOSED signal-timeframe bar
# is more than this many bar-lengths behind wall clock, the symbol is skipped
# for new entries that cycle (funnel reject reason "stale_data"). Open-trade
# management is untouched. 0 = off. Synthetic data is exempt.
STALE_ENTRY_GUARD_BARS=3

# -- Extra knobs -------------------------------------------------------------
QUOTE_ASSET=USDT
ORDERBOOK_DEPTH=20
# Total open notional cap as % of balance. 200% lets up to MAX_OPEN_TRADES (4)
# typical positions (~50% notional each) coexist; lower it to be more cautious.
MAX_PORTFOLIO_EXPOSURE_PCT=200

# -- Telegram (OPTIONAL; leave blank to disable) -----------------------------
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- Binance keys (Live Stage 1: READ-ONLY account view; optional) ------------
# Leave blank for paper/public data (adapter reports "keys_absent").
# When set, the engine runs GET-class account reads only (balance, positions,
# open orders, exchangeInfo filters, leverage brackets, fees, time drift).
# Use a READ-ONLY key: a key with withdraw enabled is flagged "unsafe_key".
# Do NOT commit real keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Slow refresh timer for the read-only account adapter (seconds; outside the
# trade cycle's critical path).
BINANCE_ACCOUNT_REFRESH_SEC=300

# -- Live safety gate ---------------------------------------------------------
# Three-factor lock: LIVE_ENABLED + LIVE_HUMAN_CONFIRM + Telegram
# `/livemode confirm <token>` (applied on restart). REAL order sending
# (Stage 3) additionally requires LIVE_SEND_ORDERS=true — with it false,
# live mode still simulates every order, exactly as before Stage 3.
# A TRADE-ONLY key is required for live (withdraw-enabled keys are flagged
# unsafe); start with canary risk. Turning LIVE_SEND_ORDERS on is a real-money
# decision — read LIVE_READY_CHECKLIST.md first.
LIVE_ENABLED=false
LIVE_HUMAN_CONFIRM=
LIVE_SEND_ORDERS=false
LIVE_CANARY_RISK_PCT=0.1
LIVE_ORDER_TIMEOUT_SEC=5
LIVE_MAX_RETRIES=2
